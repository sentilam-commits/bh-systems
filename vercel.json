{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/www.bhsystems.co/(.*)",
      "destination": "https://bhsystems.co/$1",
      "permanent": true
    },
    {
      "source": "/demo/cafe-cordillera",
      "destination": "/demo/",
      "permanent": false
    },
    {
      "source": "/demo/cafe-cordillera/",
      "destination": "/demo/",
      "permanent": false
    },
    {
      "source": "/demo-cafe",
      "destination": "/demo/",
      "permanent": false
    },
    {
      "source": "/demo-cafe/",
      "destination": "/demo/",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
